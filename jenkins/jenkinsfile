pipeline {
    agent any

    environment {
        // ---- CONFIGURATION DES USER / IMAGES ----
        DOCKER_USER      = 'judickael040'
        IMAGE_NAME       = 'spam_detection'
        IMAGE_TAG        = "${BUILD_NUMBER}" 

        // ---- CONFIGURATION DES CREDENTIALS ID (JENKINS) ----
        REGISTRY_CRED_ID = 'dockerhub-credentials-id'
        COSIGN_CRED_ID   = 'cosign-private-key' 

        // ---- ENVIRONNEMENTS ----
        ENV_TEST    = 'Testing-Environment'
        ENV_RAPPORT = 'Security-Reports'
        ENV_PROD    = 'Production-Environment'
        
        // ---- CONFIGURATION MLFLOW ----
        MLFLOW_TRACKING_URI = 'http://localhost:5000'
        MLFLOW_ALLOW_FILE_STORE = 'true'
    }

    stages {

        // ==========================================
        // STAGE 1 : GIT CLONE
        // ==========================================
        stage('Git Clone Project') {
            steps {
                echo "Récupération du projet depuis GitHub..."
                git branch: 'main', url: 'https://github.com/judickaelrabeharisonharinirina/Detection-de-spam.git'
            }
        }

        // ==========================================
        // STAGE 2 : SETUP ENV
        // ==========================================
        stage('Setup Environment') {
            steps {
                echo "Configuration de l'environnement virtuel Python..."
                sh '''
                python3 -m venv venv --without-pip
                curl -sS https://bootstrap.pypa.io/get-pip.py -o get-pip.py
                venv/bin/python3 get-pip.py
                venv/bin/pip install --upgrade pip
                venv/bin/pip install -r docker/requirements.txt
                '''
            }
        }

        // ==========================================
        // STAGE 3 : ENTRAÎNEMENT ML + CONFIG MLFLOW
        // ==========================================
        stage('ML Training & MLflow Tracking') {
            steps {
                sh "ls -R ."
                echo "Lancement de l'entraînement du modèle avec suivi MLflow..."
                sh """
                venv/bin/python3 src/predict.py
                """
            }
        }

        // ==========================================
        // STAGE 4 : DOCKER BUILD (Direct et natif)
        // ==========================================
        stage('Docker Build') {
            steps {
                echo "Construction de l'image Docker..."
                sh """
                docker build -t ${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG} -f docker/Dockerfile .
                docker tag ${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG} ${DOCKER_USER}/${IMAGE_NAME}:latest
                """
            }
        }

        // ==========================================
        // STAGE 5 : TRIVY SCAN (Version Windows robuste)
        // ==========================================
        stage('Trivy Scan') {
            steps {
                echo 'Analyse de sécurité avec Trivy...'
                // On retire le montage de volume buggé sous Windows (-v) et on redirige directement le flux HTML (>)
                sh """
                    docker run --rm \
                    -v /var/run/docker.sock:/var/run/docker.sock \
                    aquasec/trivy:latest image \
                    --format template --template "@contrib/html.tpl" \
                    ${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG} > trivy-report.html
                """
            }
        }

        // ==========================================
        // STAGE 6 : PUSH & SIGN
        // ==========================================
        stage('Push & Sign') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: "${REGISTRY_CRED_ID}", usernameVariable: 'DOCKER_USER_ENV', passwordVariable: 'DOCKER_PASS'),
                    file(credentialsId: "${COSIGN_CRED_ID}", variable: 'COSIGN_KEY_PATH'),
                    string(credentialsId: 'cosign-password', variable: 'COSIGN_PASSWORD')
                ]) {
            
                    echo 'Connexion à Docker Hub...'
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER_ENV --password-stdin"
             
                    echo 'Push des images Docker...'
                    sh "docker push ${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
                    sh "docker push ${DOCKER_USER}/${IMAGE_NAME}:latest"
            
                    echo 'Signature de l\'image avec Cosign...'
                    sh """
                        COSIGN_PRIVATE_KEY=\$(cat \$COSIGN_KEY_PATH)

                        docker run --rm \
                          -e COSIGN_PASSWORD=\$COSIGN_PASSWORD \
                          -e COSIGN_KEY="\$COSIGN_PRIVATE_KEY" \
                          -e COSIGN_REGISTRY_USERNAME=\$DOCKER_USER_ENV \
                          -e COSIGN_REGISTRY_PASSWORD=\$DOCKER_PASS \
                          gcr.io/projectsigstore/cosign:v2.2.3 sign \
                          --key env://COSIGN_KEY \
                          --tlog-upload=false \
                          --yes \
                          ${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG}
                    """
                    echo 'Signature réussie ! ✅'
                }
            }
        }

        // ==========================================
        // STAGE 7 : DÉPLOIEMENT EN PRODUCTION (ANSIBLE)
        // ==========================================
        stage('Deploy with Ansible') {
            steps {
                echo "Installation des dépendances et déploiement via Ansible..."
                sh """
                venv/bin/pip install ansible-core docker requests
                venv/bin/ansible-galaxy collection install community.docker

                venv/bin/ansible-playbook ansible/deploy.yml \
                -i ansible/hosts.ini \
                --extra-vars "docker_image_user=${DOCKER_USER} docker_image_name=${IMAGE_NAME} docker_image_tag=${IMAGE_TAG} ansible_python_interpreter=\$(pwd)/venv/bin/python3"
                """
            }
        }
    }

    post {
        always {
            echo "Nettoyage de la session..."
            sh 'docker logout || true'
            sh 'rm -f get-pip.py'
        }
        success {
            echo "SUCCESS 🚀 L'application Spam Detection a été entraînée, scannée, signée et déployée !"
            // Capture le rapport directement à la racine
            archiveArtifacts artifacts: 'trivy-report.html', allowEmptyArchive: false
        }
        failure {
            echo "FAILED ❌ Le pipeline a échoué."
        }
    }
}
