# 1) Image de base officielle Python 3.11
FROM python:3.11-slim

WORKDIR /app

# 2) Dépendances système
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    wget \
    && rm -rf /var/lib/apt/lists/*

# 3) Installation et mise à jour des packages Python
COPY docker/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 4) Téléchargement complet de TOUTES les ressources NLTK requises
RUN pip install --upgrade nltk && python -m nltk.downloader punkt punkt_tab stopwords wordnet omw-1.4

# 5) Copie de l'arborescence de ton projet
COPY src/ ./src/                                                      
# 6) Copie des Assets à la racine (pour matcher le ../../Assets de Traitement.py)
# Copie le dossier Assets dans /app/Assets/
COPY Assets/ ./Assets/
COPY models/ ./models/
# 7) Configuration de l'environnement et ports
ENV PYTHONPATH="/app/src"
EXPOSE 8000
EXPOSE 8501

# 8) Lancement SIMULTANÉ des deux services (FastAPI via ton script + Streamlit)
CMD ["sh", "-c", "python src/app.py & python -m streamlit run src/interface.py --server.port 8501 --server.address 0.0.0.0"]